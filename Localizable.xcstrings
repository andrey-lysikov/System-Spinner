    "System Spinner provides macOS system information in status bar.\nMinimal, small and light.\n\nAuthor: @Andrey.Lysikov\nVersion: %@" : {
      "comment" : "A message displayed in the alert window that shows information about the app.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System SpinnerはmacOSのシステム情報をステータスバーに表示します。ミニマルで小さく、そして軽量です。\n\nAuthor: @Andrey.Lysikov\nVersion: %@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System Spinner программа которая показывает утилизацию ресурсов вашего компьютера. Небольшая и легкая.\n\nАвтор: @Andrey.Lysikov\nВерсия: %@"
          }
        }
      }
    },
